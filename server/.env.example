# Optional: Add your GitHub Personal Access Token to increase rate limit
# Without token: 60 requests/hour
# With token: 5000 requests/hour
# Get one at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=your_github_token_here

# Port the server runs on (default: 5000)
PORT=5000

# URL of your deployed frontend (for CORS in production)
# Example: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
